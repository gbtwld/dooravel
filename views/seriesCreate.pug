extends ./layouts/main

block content
    form.series-form(action=`/series${routes.seriesCreate}`, method="post", enctype="multipart/form-data")
        input(type="text",name="series_title",placeholder="제목을 입력하세요.",required="true")
        textarea(type="text",name="series_contents",placeholder="내용을 입력하세요.",required="true")
        input(type="submit", value="등록")